<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <!--
    ================================================================
    NAVISWORKS VERSION TARGETING
    One build per Navisworks version. Pick the version with:
        msbuild /p:NavisworksVersion=2026
    Default: newest installed version (2028 → 2024 probe order).
    API reference DLLs resolve from, in order:
      1. Refs\<version>\   (checked-in copies for versions not installed here)
      2. C:\Program Files\Autodesk\Navisworks Manage <version>\
    ================================================================
  -->
  <PropertyGroup>
    <NavisworksVersion Condition="'$(NavisworksVersion)' == '' AND Exists('C:\Program Files\Autodesk\Navisworks Manage 2028')">2028</NavisworksVersion>
    <NavisworksVersion Condition="'$(NavisworksVersion)' == '' AND Exists('C:\Program Files\Autodesk\Navisworks Manage 2027')">2027</NavisworksVersion>
    <NavisworksVersion Condition="'$(NavisworksVersion)' == '' AND Exists('C:\Program Files\Autodesk\Navisworks Manage 2026')">2026</NavisworksVersion>
    <NavisworksVersion Condition="'$(NavisworksVersion)' == '' AND Exists('C:\Program Files\Autodesk\Navisworks Manage 2025')">2025</NavisworksVersion>
    <NavisworksVersion Condition="'$(NavisworksVersion)' == '' AND Exists('C:\Program Files\Autodesk\Navisworks Manage 2024')">2024</NavisworksVersion>
    <NavisworksVersion Condition="'$(NavisworksVersion)' == ''">2027</NavisworksVersion>

    <NavisworksPath Condition="'$(NavisworksPath)' == '' AND Exists('$(MSBuildProjectDirectory)\Refs\$(NavisworksVersion)\Autodesk.Navisworks.Api.dll')">$(MSBuildProjectDirectory)\Refs\$(NavisworksVersion)</NavisworksPath>
    <NavisworksPath Condition="'$(NavisworksPath)' == ''">C:\Program Files\Autodesk\Navisworks Manage $(NavisworksVersion)</NavisworksPath>
  </PropertyGroup>

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">x64</Platform>
    <ProjectGuid>{A1B2C3D4-1234-5678-9ABC-DEF012345678}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>ClashRuleEngine</RootNamespace>
    <AssemblyName>ClashRuleEngine</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>latest</LangVersion>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <!-- e.g. NW2027 — for version-specific conditional compilation -->
    <NavisDefine>NW$(NavisworksVersion)</NavisDefine>
    <!-- 2027 moved the tests collection into a folder tree (see Services\ClashApiCompat.cs) -->
    <NavisDefine Condition="'$(NavisworksVersion)' &gt;= '2027'">$(NavisDefine);NW_TESTS_TREE</NavisDefine>
  </PropertyGroup>

  <!-- Debug config -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\x64\Debug\$(NavisworksVersion)\</OutputPath>
    <DefineConstants>DEBUG;TRACE;$(NavisDefine)</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <!-- Release config -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x64' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\x64\Release\$(NavisworksVersion)\</OutputPath>
    <DefineConstants>TRACE;$(NavisDefine)</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <!-- Standard .NET Framework references -->
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Web.Extensions" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data" />
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsFormsIntegration" />
    <Reference Include="System.Windows.Forms" />
  </ItemGroup>

  <!-- Navisworks API References — Private=False so they are NOT copied to output -->
  <ItemGroup>
    <Reference Include="Autodesk.Navisworks.Api">
      <HintPath>$(NavisworksPath)\Autodesk.Navisworks.Api.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Autodesk.Navisworks.Clash">
      <HintPath>$(NavisworksPath)\Autodesk.Navisworks.Clash.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Autodesk.Navisworks.Automation">
      <HintPath>$(NavisworksPath)\Autodesk.Navisworks.Automation.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Autodesk.Navisworks.Controls">
      <HintPath>$(NavisworksPath)\Autodesk.Navisworks.Controls.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <!-- C# source files -->
  <ItemGroup>
    <Compile Include="Models\ClashRule.cs" />
    <Compile Include="Models\RuleCondition.cs" />
    <Compile Include="Models\TestRuleSet.cs" />
    <Compile Include="Plugin\ClashRuleEnginePlugin.cs" />
    <Compile Include="Plugin\ClashMarkerPlugins.cs" />
    <Compile Include="Plugin\BatchClashExtractPlugin.cs" />
    <Compile Include="Services\AiRuleGenerator.cs" />
    <Compile Include="Services\ClashApiCompat.cs" />
    <Compile Include="Services\ClashMarkerService.cs" />
    <Compile Include="Services\ClashNavigationService.cs" />
    <Compile Include="Services\ClashProcessingService.cs" />
    <Compile Include="Services\ClaudeApiService.cs" />
    <Compile Include="Services\DisciplineClassifier.cs" />
    <Compile Include="Services\ClashTestScanner.cs" />
    <Compile Include="Services\RulePersistenceService.cs" />
    <Compile Include="Services\ModelPropertyScanner.cs" />
    <Compile Include="Services\SessionExportService.cs" />
    <Compile Include="UI\Converters.cs" />
    <Compile Include="UI\ClashMatrixDialog.cs" />
    <Compile Include="UI\ExportProgressWindow.cs" />
    <Compile Include="UI\AiAssistDialog.xaml.cs">
      <DependentUpon>AiAssistDialog.xaml</DependentUpon>
    </Compile>
    <Compile Include="UI\ClashInspectorDialog.xaml.cs">
      <DependentUpon>ClashInspectorDialog.xaml</DependentUpon>
    </Compile>
    <Compile Include="UI\RuleEditorDialog.xaml.cs">
      <DependentUpon>RuleEditorDialog.xaml</DependentUpon>
    </Compile>
    <Compile Include="UI\RuleEnginePanel.xaml.cs">
      <DependentUpon>RuleEnginePanel.xaml</DependentUpon>
    </Compile>
    <Compile Include="UI\SettingsDialog.xaml.cs">
      <DependentUpon>SettingsDialog.xaml</DependentUpon>
    </Compile>
  </ItemGroup>

  <!-- XAML pages -->
  <ItemGroup>
    <Page Include="UI\AiAssistDialog.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Include="UI\ClashInspectorDialog.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Include="UI\RuleEditorDialog.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Include="UI\RuleEnginePanel.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Include="UI\SettingsDialog.xaml">
      <SubType>Designer</SubType>
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>

  <!-- Other files -->
  <ItemGroup>
    <None Include="PackageContents.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Ribbon XAML — MUST be EmbeddedResource for Navisworks to find it -->
  <ItemGroup>
    <EmbeddedResource Include="Plugin\ClashRuleEngineRibbon.xaml" />
  </ItemGroup>

  <!-- Post-build: best-effort copy to the user Plugins folder for quick testing (Debug only).
       Release deployment is handled by tools\deploy.ps1 -->
  <Target Name="CopyToNavisworksPlugins" AfterTargets="Build" Condition="'$(Configuration)' == 'Debug'">
    <PropertyGroup>
      <PluginFolder>$(AppData)\Autodesk Navisworks Manage $(NavisworksVersion)\Plugins</PluginFolder>
    </PropertyGroup>
    <MakeDir Directories="$(PluginFolder)" ContinueOnError="true" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(PluginFolder)" ContinueOnError="true" />
  </Target>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

</Project>
