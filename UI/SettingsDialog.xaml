<Window x:Class="ClashRuleEngine.UI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClashRuleEngine.UI"
        Title="Clash Rule Engine — Settings" Width="760" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9FA" Foreground="#1A1A2E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <local:HexToBrushConverter x:Key="HexToBrush"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderBrush="#E5E7EB">

            <!-- ───────────── DISCIPLINES & HIERARCHY ───────────── -->
            <TabItem Header="Disciplines &amp; Hierarchy">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" x:Name="chkFallback" Margin="2,4,0,6"
                              FontSize="12.5" FontWeight="SemiBold" Foreground="#111827"
                              Content="Auto-assign unmatched clashes using the discipline hierarchy"/>

                    <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11" Foreground="#6B7280" Margin="2,0,2,8">
                        Order = precedence: the discipline at the TOP is hardest to move (right-of-way).
                        In any clash the LOWER discipline is held responsible and the clash is assigned to its owner.
                        Rules always win when they match — the hierarchy only fills the gaps.
                        "Keywords" are matched against each element's source file name and key properties.
                    </TextBlock>

                    <ListBox Grid.Row="2" x:Name="lstDisciplines" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="6,0,0,6"
                                                Background="{Binding Color, Converter={StaticResource HexToBrush}}"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                            <Button Content="&#x25B2;" Width="26" Height="24" FontSize="11"
                                                    Style="{StaticResource Btn}" Click="OnMoveUp" Tag="{Binding}"
                                                    Margin="0,0,0,3" ToolTip="Higher precedence"/>
                                            <Button Content="&#x25BC;" Width="26" Height="24" FontSize="11"
                                                    Style="{StaticResource Btn}" Click="OnMoveDown" Tag="{Binding}"
                                                    ToolTip="Lower precedence"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="8,8,8,8">
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                     FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="DETECT WITH KEYWORDS (comma-separated)" Style="{StaticResource FieldLabel}" Margin="0,6,0,2"/>
                                            <TextBox Text="{Binding KeywordsCsv, UpdateSourceTrigger=LostFocus}"
                                                     TextWrapping="Wrap" FontSize="11.5"/>
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="OWNER / ASSIGNEE (optional — defaults to trade name)" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox IsEditable="True" FontSize="12"
                                                              ItemsSource="{Binding AvailableAssignees, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              Text="{Binding Assignee, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="GROUP (optional)" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding GroupName, UpdateSourceTrigger=LostFocus}" FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <Button Grid.Column="3" Content="&#x2715;" Width="26" Height="26" FontSize="11"
                                                VerticalAlignment="Top" Margin="4,8,8,0"
                                                Foreground="#DC2626" Background="Transparent" BorderBrush="#FCA5A5"
                                                Style="{StaticResource Btn}" Click="OnDeleteDiscipline" Tag="{Binding}"
                                                ToolTip="Remove discipline"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ Add Discipline" Style="{StaticResource Btn}" Click="OnAddDiscipline"/>
                        <Button Content="Restore Defaults" Style="{StaticResource Btn}" Click="OnRestoreDefaults" Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ───────────── LISTS ───────────── -->
            <TabItem Header="Assignees &amp; Groups">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" FontSize="11" Foreground="#6B7280" Margin="2,4,2,8"
                               Text="One per line. These pre-populate the dropdowns in the rule editor and the discipline owners above. (Assignees used by rules/disciplines also appear automatically.)"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" Text="ASSIGNEES" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtAssignees" AcceptsReturn="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
                        </DockPanel>
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" Text="GROUPS" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtGroups" AcceptsReturn="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ───────────── GENERAL ───────────── -->
            <TabItem Header="General">
                <StackPanel Margin="10">
                    <TextBlock Text="PROJECT NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtProjectName" Margin="0,0,0,12"/>

                    <TextBlock Text="CLAUDE API KEY" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtApiKey" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#9CA3AF" Margin="0,0,0,12"
                               Text="Stored locally in the project's .clashre file. Used by the planned Smart Assign / rules-by-example feature."/>

                    <TextBlock x:Name="txtConfigStats" FontSize="11" Foreground="#6B7280"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- FOOTER -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource Btn}" Click="OnCancel" Width="80" Margin="0,0,8,0"/>
            <Button Content="Save" Style="{StaticResource BtnPrimary}" Click="OnSave" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
