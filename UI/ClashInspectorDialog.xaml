<Window x:Class="ClashRuleEngine.UI.ClashInspectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClashRuleEngine.UI"
        Title="Clash Inspector" Width="900" Height="660"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9FA" Foreground="#1A1A2E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <local:HexToBrushConverter x:Key="HexToBrush"/>

        <Style x:Key="SmBtn" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource SmBtn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Clash header -->
            <RowDefinition Height="*"/>      <!-- Side-by-side properties -->
            <RowDefinition Height="Auto"/>   <!-- Selected conditions preview -->
            <RowDefinition Height="Auto"/>   <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- CLASH HEADER -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="4" Padding="12,8"
                BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="txtClashName" FontSize="14" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock x:Name="txtDescription" FontSize="11" Foreground="#6B7280"
                               Margin="0,2,0,0" TextWrapping="Wrap" MaxHeight="36"/>
                </StackPanel>
                <Border Grid.Column="1" x:Name="bdStatus" CornerRadius="3" Padding="10,4"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock x:Name="txtStatus" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- SIDE-BY-SIDE PROPERTIES -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Item A -->
            <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="4"
                    BorderBrush="#BFDBFE" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#EFF6FF" Padding="10,8" CornerRadius="4,4,0,0"
                            BorderBrush="#BFDBFE" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="ITEM A" FontSize="10" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,2"/>
                            <TextBlock x:Name="txtItem1Name" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#1E3A8A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <TextBlock DockPanel.Dock="Top" Text="Click any property row to add it as a rule condition"
                               FontSize="10" Foreground="#93C5FD" Padding="10,4,10,4" FontStyle="Italic"
                               Background="#F8FBFF"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="pnlItem1Props" Margin="0,2,0,4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="#E5E7EB" Cursor="SizeWE"/>

            <!-- Item B -->
            <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="4"
                    BorderBrush="#FED7AA" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#FFF7ED" Padding="10,8" CornerRadius="4,4,0,0"
                            BorderBrush="#FED7AA" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="ITEM B" FontSize="10" FontWeight="Bold" Foreground="#C2410C" Margin="0,0,0,2"/>
                            <TextBlock x:Name="txtItem2Name" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#9A3412" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <TextBlock DockPanel.Dock="Top" Text="Click any property row to add it as a rule condition"
                               FontSize="10" Foreground="#FDBA74" Padding="10,4,10,4" FontStyle="Italic"
                               Background="#FFFDF8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="pnlItem2Props" Margin="0,2,0,4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- SELECTED CONDITIONS PREVIEW -->
        <Border Grid.Row="2" x:Name="bdSelectedConditions" Background="#F0FDF4" CornerRadius="4"
                Padding="10,8" BorderBrush="#86EFAC" BorderThickness="1"
                Margin="0,8,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="CONDITIONS FOR NEW RULE:" FontSize="10" FontWeight="Bold"
                           Foreground="#166534" Margin="0,0,0,4"/>
                <StackPanel x:Name="pnlSelectedConditions"/>
            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtSelectionHint" VerticalAlignment="Center" FontSize="11"
                       Foreground="#6B7280"
                       Text="Select properties above to pre-fill the rule editor, or click Create Rule for an empty rule"/>
            <Button Grid.Column="1" Content="Clear Selection" Style="{StaticResource SmBtn}"
                    Click="OnClearSelection" Margin="0,0,6,0"/>
            <Button Grid.Column="2" Content="Create Rule" Style="{StaticResource BtnPrimary}"
                    Click="OnCreateRule" Margin="0,0,6,0" Width="100"/>
            <Button Grid.Column="3" Content="Close" Style="{StaticResource SmBtn}"
                    Click="OnClose" Width="70"/>
        </Grid>
    </Grid>
</Window>
