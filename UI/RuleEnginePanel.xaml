<UserControl x:Class="ClashRuleEngine.UI.RuleEnginePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClashRuleEngine.UI"
             Background="#F8F9FA" Foreground="#1A1A2E">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:HexToBrushConverter x:Key="HexToBrush"/>
        <local:EnabledToOpacityConverter x:Key="EnabledToOpacity"/>
        <local:PriorityToDisplayConverter x:Key="PriorityToDisplay"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="CaretBrush" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Dropdown items + selection highlight -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1A1A2E"/>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Background" Value="#FEF2F2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Clash test selector -->
            <RowDefinition Height="*"/>     <!-- Tab content -->
            <RowDefinition Height="Auto"/>  <!-- Results panel -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="12,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Clash Rule Engine" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                    <TextBlock x:Name="txtStatus" Text="Select a clash test" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ New Rule" Style="{StaticResource BtnPrimary}" Click="OnAddRule" Margin="0,0,6,0"/>
                    <Button Content="Import" Style="{StaticResource Btn}" Click="OnImportConfig"
                            ToolTip="Import a .clashre config (rules, hierarchy, assignees) from anywhere"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CLASH TEST SELECTOR + GLOBAL GROUPING -->
        <Border Grid.Row="1" Background="#F9FAFB" Padding="12,8" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Clash test:" VerticalAlignment="Center" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbClashTest" Grid.Column="1" FontSize="12" SelectionChanged="OnClashTestChanged"/>
                    <Button Grid.Column="2" Content="Matrix" Style="{StaticResource Btn}" Click="OnShowMatrix" Margin="6,0,0,0" FontSize="11" ToolTip="Clash matrix — all test pairs at a glance"/>
                    <Button Grid.Column="3" Content="Refresh" Style="{StaticResource Btn}" Click="OnRefreshTests" Margin="6,0,0,0" FontSize="11"/>
                </Grid>

                <!-- GLOBAL GROUPING (applies to all tests) -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Grouping (all tests):" VerticalAlignment="Center" Foreground="#6B7280"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbGroupMode" Grid.Column="1" FontSize="12" VerticalAlignment="Center"
                              ToolTip="How active clashes are clustered into Clash Detective groups when rules run.">
                        <ComboBoxItem Content="None — every clash on its own"/>
                        <ComboBoxItem Content="Shared element — clashes touching the same item"/>
                        <ComboBoxItem Content="Proximity — clashes within the distance below"/>
                        <ComboBoxItem Content="Grid — one group per grid cell (e.g. H-22)"/>
                        <ComboBoxItem Content="Level — one group per building level"/>
                        <ComboBoxItem Content="Assignee / trade — one group per trade"/>
                        <ComboBoxItem Content="Hybrid — shared element OR proximity"/>
                        <ComboBoxItem Content="Grid + trade — split each cell by trade (named by grid)"/>
                    </ComboBox>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="Proximity (m):" VerticalAlignment="Center" Foreground="#6B7280" FontSize="11" Margin="0,0,4,0"/>
                        <TextBox x:Name="txtThreshold" FontSize="12" Width="50" VerticalAlignment="Center"
                                 ToolTip="Distance for Proximity / Hybrid grouping (metres)."/>
                    </StackPanel>
                    <CheckBox x:Name="chkAssignByGroup" Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0"
                              FontSize="11" Foreground="#1A1A2E" Content="Group-then-assign"
                              ToolTip="After clustering, every clash in a group is given the same assignee — the one most members resolved to."/>
                </Grid>
                <CheckBox x:Name="chkOnlyNew" Margin="0,6,0,0" FontSize="11" Foreground="#1A1A2E"
                          Content="Only assign NEW clashes (leave active / assigned / grouped clashes as-is)"
                          ToolTip="Incremental re-run: only New + unassigned clashes get assigned/approved/grouped; everything already triaged is left exactly as it is."/>
            </StackPanel>
        </Border>

        <!-- TAB STRIP + CONTENT -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Tab strip -->
                <RowDefinition Height="*"/>     <!-- Tab content -->
            </Grid.RowDefinitions>

            <!-- TAB STRIP -->
            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                        <Border x:Name="bdTabRules" Padding="12,8" Cursor="Hand"
                                MouseLeftButtonDown="OnTabRulesClick"
                                BorderBrush="#2563EB" BorderThickness="0,0,0,2" Background="Transparent">
                            <TextBlock x:Name="txtTabRules" Text="Rules" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB"/>
                        </Border>
                        <Border x:Name="bdTabClashes" Padding="12,8" Cursor="Hand"
                                MouseLeftButtonDown="OnTabClashesClick"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2" Background="Transparent">
                            <TextBlock x:Name="txtTabClashes" Text="Clashes" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                        </Border>
                        <Border x:Name="bdTabGeneral" Padding="12,8" Cursor="Hand"
                                MouseLeftButtonDown="OnTabGeneralClick"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2" Background="Transparent">
                            <TextBlock x:Name="txtTabGeneral" Text="General" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RULES TAB CONTENT -->
            <Grid Grid.Row="1" x:Name="pnlTabRules">

                <!-- Rule list -->
                <ListBox x:Name="lstRules" Background="Transparent" BorderThickness="0" Padding="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="OnRuleListPreviewMouseDown"
                         PreviewMouseMove="OnRuleListPreviewMouseMove"
                         Drop="OnRuleListDrop" DragOver="OnRuleListDragOver">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" CornerRadius="6" BorderThickness="1" BorderBrush="#E5E7EB"
                                    Opacity="{Binding IsEnabled, Converter={StaticResource EnabledToOpacity}}" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding Color, Converter={StaticResource HexToBrush}}" CornerRadius="6,0,0,6"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,8" Width="36">
                                        <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityToDisplay}}" FontSize="14" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center"/>
                                        <TextBlock Text="&#x22EE;&#x22EE;" FontSize="10" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="4,8,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                      Click="OnToggleRuleEnabled" Tag="{Binding}"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                                      ToolTip="Enable / disable this rule (disabled rules are skipped when running)"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Conditions}" Margin="0,3,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="10.5" Foreground="#6B7280" Margin="0,1,0,0">
                                                        <Run Text="  &#x2022;  "/><Run Text="{Binding Mode=OneWay}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border Background="#F0FDF4" CornerRadius="3" Padding="5,2" Margin="0,0,4,0">
                                                <TextBlock FontSize="10" Foreground="#16A34A">
                                                    <Run Text="Group: "/><Run Text="{Binding GroupName}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#FFFBEB" CornerRadius="3" Padding="5,2">
                                                <TextBlock FontSize="10" Foreground="#D97706">
                                                    <Run Text="Assign: "/><Run Text="{Binding AssigneeDisplay, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Grid.Column="3" VerticalAlignment="Center" Margin="4,4,8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Reorder: clear text labels Up / Dn (glyph arrows render faintly in the UI font) -->
                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            <Button Content="Up" Width="38" Height="26" FontSize="11" FontWeight="SemiBold"
                                                    Foreground="#374151" Style="{StaticResource Btn}" Padding="0"
                                                    Click="OnMoveRuleUp" Tag="{Binding}" Margin="0,0,0,4" ToolTip="Move rule up (higher priority)"/>
                                            <Button Content="Dn" Width="38" Height="26" FontSize="11" FontWeight="SemiBold"
                                                    Foreground="#374151" Style="{StaticResource Btn}" Padding="0"
                                                    Click="OnMoveRuleDown" Tag="{Binding}" ToolTip="Move rule down (lower priority)"/>
                                        </StackPanel>
                                        <!-- Edit + Delete: text labels (pencil glyph U+270F is missing from the UI font) -->
                                        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                            <Button Content="Edit" Width="52" Height="26" FontSize="11" FontWeight="SemiBold"
                                                    Background="#EFF6FF" Foreground="#2563EB" BorderBrush="#BFDBFE"
                                                    Style="{StaticResource Btn}" Click="OnEditRule" Tag="{Binding}" Padding="0"
                                                    Margin="0,0,0,4" ToolTip="Edit rule"/>
                                            <Button Content="Delete" Width="52" Height="26" FontSize="11" FontWeight="SemiBold"
                                                    Style="{StaticResource BtnDanger}" Click="OnDeleteRule" Tag="{Binding}"
                                                    Padding="0" ToolTip="Delete rule"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state (rules) -->
                <StackPanel x:Name="pnlEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No rules for this test" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a clash test above, then click '+ New Rule'" FontSize="11" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"
                               TextAlignment="Center" MaxWidth="240"/>
                </StackPanel>
            </Grid>

            <!-- CLASHES TAB CONTENT -->
            <Grid Grid.Row="1" x:Name="pnlTabClashes" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                    <RowDefinition Height="*"/>     <!-- List / empty state -->
                </Grid.RowDefinitions>

                <!-- Clash tab toolbar -->
                <Border Grid.Row="0" Background="#FFFFFF" Padding="8,6"
                        BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtClashCount" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#6B7280" Margin="4,0,0,0"
                                       TextWrapping="Wrap"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ToggleButton x:Name="btnMarkers" Content="3D Markers" FontSize="11"
                                              Margin="0,0,6,0" Padding="10,5" Cursor="Hand" VerticalAlignment="Center"
                                              ToolTip="Show coloured markers at each clash in the 3D view; click a marker to select it"
                                              Checked="OnToggleMarkers" Unchecked="OnToggleMarkers"/>
                                <Button Content="Refresh" Style="{StaticResource Btn}"
                                        Click="OnRefreshClashes" FontSize="11" Padding="10,5"/>
                            </StackPanel>
                        </Grid>
                        <!-- Status filter chips (built in code so counts stay live) -->
                        <WrapPanel Grid.Row="1" x:Name="pnlClashFilters" Margin="2,6,0,0"/>
                    </Grid>
                </Border>

                <!-- Clash results list -->
                <ListBox Grid.Row="1" x:Name="lstClashes" Background="Transparent"
                         BorderThickness="0" Padding="8"
                         SelectionChanged="OnClashSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,3"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="selBd" CornerRadius="6"
                                                BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="selBd" Property="BorderBrush" Value="#2563EB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" CornerRadius="5" BorderThickness="1"
                                    BorderBrush="#E5E7EB" Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>   <!-- Status strip -->
                                        <ColumnDefinition Width="*"/>   <!-- Name + items -->
                                        <ColumnDefinition Width="Auto"/><!-- Inspect button -->
                                    </Grid.ColumnDefinitions>
                                    <!-- Status colour strip -->
                                    <Border Grid.Column="0"
                                            Background="{Binding StatusColor, Converter={StaticResource HexToBrush}}"
                                            CornerRadius="5,0,0,5"/>
                                    <!-- Main content -->
                                    <StackPanel Grid.Column="1" Margin="8,6,4,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{Binding StatusColor, Converter={StaticResource HexToBrush}}"
                                                    CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="9"
                                                           FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding ClashName}" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="#1A1A2E"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock FontSize="10.5" Foreground="#6B7280" Margin="0,2,0,0">
                                            <Run Text="{Binding Item1Name}"/>
                                            <Run Text=" &#x2192; "/>
                                            <Run Text="{Binding Item2Name}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="#6B7280" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="260" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <!-- Inspect button -->
                                    <Button Grid.Column="2" Content="Inspect" Tag="{Binding}"
                                            Click="OnInspectClash" Margin="4,0,6,0"
                                            VerticalAlignment="Center" FontSize="11"
                                            Padding="8,4" Cursor="Hand" Style="{StaticResource Btn}"
                                            Background="#EFF6FF" Foreground="#2563EB"
                                            BorderBrush="#2563EB" BorderThickness="1"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state (clashes) -->
                <StackPanel x:Name="pnlClashEmptyState" Grid.Row="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No clashes found" FontSize="14" Foreground="#6B7280"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a clash test above, or click Refresh"
                               FontSize="11" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"
                               TextAlignment="Center" MaxWidth="240"/>
                </StackPanel>
            </Grid>

            <!-- GENERAL TAB CONTENT -->
            <ScrollViewer Grid.Row="1" x:Name="pnlTabGeneral" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="PROJECT NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtProjectName" Margin="0,0,0,12"/>

                    <TextBlock Text="CLAUDE API KEY" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtApiKey" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#6B7280" Margin="0,0,0,12"
                               Text="Stored locally in the project's .clashre file. Used by the AI rule generation feature."/>

                    <TextBlock x:Name="txtConfigStats" FontSize="11" Foreground="#6B7280" Margin="0,0,0,12"/>

                    <Button Content="Save" Style="{StaticResource BtnPrimary}" Click="OnSaveSetup"
                            Width="90" HorizontalAlignment="Left"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- RESULTS PANEL (after running rules) -->
        <Border Grid.Row="3" x:Name="pnlResults" Background="#FFFFFF"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header + stat chips -->
                    <RowDefinition Height="Auto"/>  <!-- Per-rule breakdown / warnings -->
                </Grid.RowDefinitions>

                <!-- Header row -->
                <Grid Grid.Row="0" Background="#F9FAFB" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="12,8,0,8">
                        <TextBlock x:Name="txtResultsTitle" Text="Run results" FontSize="12"
                                   FontWeight="Bold" Foreground="#1A1A2E"/>
                        <!-- Stat chips -->
                        <StackPanel x:Name="pnlResultStats" Orientation="Horizontal" Margin="0,6,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Dismiss" Style="{StaticResource Btn}"
                            Click="OnDismissResults" Height="28" Margin="8,8,12,8" FontSize="11"
                            ToolTip="Dismiss results"/>
                </Grid>

                <!-- Breakdown -->
                <ScrollViewer Grid.Row="1" MaxHeight="200" VerticalScrollBarVisibility="Auto"
                              Padding="12,8,12,10">
                    <StackPanel>
                        <!-- Per-rule assignment rows -->
                        <ItemsControl x:Name="lstResultRules">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB" CornerRadius="4" Padding="8,5"
                                            Margin="0,0,0,4" BorderBrush="#E5E7EB" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="2"
                                                    Background="{Binding Color, Converter={StaticResource HexToBrush}}"/>
                                            <Border Grid.Column="1" Background="#2563EB" CornerRadius="9"
                                                    MinWidth="26" Height="18" Margin="8,0,8,0">
                                                <TextBlock Text="{Binding Count}" Foreground="White" FontSize="11"
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Margin="6,0"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RuleName}" FontSize="11.5"
                                                           FontWeight="SemiBold" Foreground="#1A1A2E"/>
                                                <TextBlock FontSize="10" Foreground="#6B7280">
                                                    <Run Text="&#x2192; "/><Run Text="{Binding GroupName}"/>
                                                    <Run Text="  &#x2022;  "/><Run Text="{Binding Assignee}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Warnings -->
                        <Expander x:Name="expResultWarnings" Margin="0,4,0,0" Visibility="Collapsed">
                            <Expander.Header>
                                <TextBlock x:Name="txtResultWarningsHeader" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#D97706"/>
                            </Expander.Header>
                            <TextBlock x:Name="txtResultWarnings" FontSize="10.5" Foreground="#D97706"
                                       TextWrapping="Wrap" Margin="4,4,0,0"/>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- FOOTER — WrapPanel so the buttons reflow instead of clipping in a narrow dock.
             Primary run actions first, then a divider, then rule/export utilities. -->
        <Border Grid.Row="4" Background="#FFFFFF" Padding="8,8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <WrapPanel>
                <Button Content="Run This Test" Style="{StaticResource BtnPrimary}" Click="OnRunSelectedTest" Margin="0,0,5,5"/>
                <Button Content="Run All Tests" Style="{StaticResource Btn}" Click="OnRunAllTests" Margin="0,0,5,5"/>
                <!-- divider between run actions and utilities -->
                <Border Width="1" Background="#E5E7EB" Margin="3,2,8,7"/>
                <Button Content="AI Rules" Style="{StaticResource Btn}" Click="OnAiRules" Margin="0,0,5,5"
                        Foreground="#7C3AED" BorderBrush="#C4B5FD"
                        ToolTip="Describe your coordination rules in plain English and let Claude write them"/>
                <Button Content="Save" Style="{StaticResource Btn}" Click="OnSaveRules" Margin="0,0,5,5"/>
                <Button Content="Export Summary" Style="{StaticResource Btn}" Click="OnExportSummary" Margin="0,0,5,5"
                        Foreground="#0D9488" BorderBrush="#99F6E4"
                        ToolTip="Compact per-test assignment summary across ALL tests — small enough to paste into a prompt"/>
                <Button Content="Export Session" Style="{StaticResource Btn}" Click="OnExportSession" Margin="0,0,0,5"
                        ToolTip="Full export: every clash disposition + item properties to JSON (large)"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
